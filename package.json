{
  "name": "system-hotel-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart verona-server --update-env",
    "pm2:logs": "pm2 logs verona-server",
    "db:init": "tsx src/scripts/init_hotel_config.ts",
    "db:migrate": "tsx src/scripts/migrate_config.ts",
    "db:normalize-dates": "tsx src/scripts/normalize_dates.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^1.4.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
