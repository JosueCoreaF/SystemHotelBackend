# Variables de entorno — Backend
# Copia este archivo como .env y completa los valores

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/hotel_verona

# Puerto del servidor Express
PORT=4000

# CORS — Origen permitido del frontend (en producción, la URL pública del frontend)
CORS_ORIGIN=http://localhost:5173

# Supabase (para operaciones server-side si aplica)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP para notificaciones de email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Hotel Verona <no-reply@hotelverona.com>"

# Correo/WhatsApp del administrador para recibir notificaciones
ADMIN_NOTIFICATION_EMAIL=admin@hotelverona.com
ADMIN_WHATSAPP_NUMBER=+50400000000

# WhatsApp API (opcional)
WHATSAPP_API_URL=https://api.whatsapp-provider.com/send
WHATSAPP_API_TOKEN=your-token

# Hora de actualización diaria del tipo de cambio (0–23)
EXCHANGE_UPDATE_HOUR=6
EXCHANGE_UPDATE_MINUTE=0
